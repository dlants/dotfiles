#!/bin/bash
# pane-nav: escalating pane navigation
# Tries to switch tmux panes in the given direction. If at the edge,
# falls back to hammerspoon for L/R to switch macOS windows.
#
# Usage: pane-nav <L|R|U|D>

dir="$1"

# Need an active tmux session to do the tmux step.
# Use $TMUX_PANE when set (tmux binding / nvim subprocess) so we pin to the
# pane that initiated navigation, not whatever happens to be active later.
if [ -n "$TMUX" ]; then
  pane="${TMUX_PANE:-$(tmux display-message -p '#{pane_id}')}"
  tmux select-pane -t "$pane" -"$dir" 2>/dev/null
  new=$(tmux display-message -p '#{pane_id}')
  if [ "$pane" != "$new" ]; then
    exit 0
  fi
fi

# At the tmux edge (or no tmux). Escalate to hammerspoon for L/R only.
case "$dir" in
  L) token=left ;;
  R) token=right ;;
  *) exit 0 ;;
esac

# Direct path: host has the hammerspoon CLI.
HS=/opt/homebrew/bin/hs
if [ -x "$HS" ]; then
  "$HS" -c "switchWindow('$token')" >/dev/null
  exit 0
fi

# Fallback: dev container has no `hs` binary, but shares ~/dev-in-docker-shared-files
# with the host. Append a token line; the host's hammerspoon pathwatcher will
# read new lines and call switchWindow.
SIGNAL_FILE="$HOME/dev-in-docker-shared-files/pane-nav-signal"
if [ -d "$(dirname "$SIGNAL_FILE")" ]; then
  echo "$token" >> "$SIGNAL_FILE"
fi
